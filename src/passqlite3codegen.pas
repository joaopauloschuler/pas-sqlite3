  MakeFD(aBuiltinFuncs[64], 1, FUNC_ENC, @math1Func,  nil, 'acos');
  aBuiltinFuncs[64].pUserData := Pointer(PtrInt(MATH_TAG_ACOS));
  MakeFD(aBuiltinFuncs[65], 1, FUNC_ENC, @math1Func,  nil, 'asin');
