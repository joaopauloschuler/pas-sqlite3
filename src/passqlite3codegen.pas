  sqlite3DbFree(db, pTrigger^.zName);
  sqlite3DbFree(db, pTrigger^.table);
  sqlite3ExprDelete(db, pTrigger^.pWhen);
  sqlite3IdListDelete(db, pTrigger^.pColumns);
  sqlite3DbFree(db, pTrigger);
end;

