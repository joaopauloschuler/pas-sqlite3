  end;

  { --- TUnpackedRecord (sizeof=40) --- }
  TUnpackedRecordU = record
    case Integer of
      0: (z: PAnsiChar);
      1: (i: i64);
  end;
  TUnpackedRecord = record
    pKeyInfo:   PKeyInfo2;            { 8 bytes @ 0 }
