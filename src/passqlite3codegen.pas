  end;
  snpFmt(SizeOf(buf), buf, '%02d:%02d:%05.3f', [dt.hr, dt.mi, dt.s]);
  sqlite3_result_text(pCtx, buf, -1, SQLITE_TRANSIENT);
end;

procedure datetimeFunc(pCtx: Psqlite3_context; argc: i32; argv: PPMem); cdecl;
var
  dt: TDateTime2;
  z: PAnsiChar;
  buf: array[0..23] of AnsiChar;
  jd: Double;
  y2, m2, d2, h2, mn2: i32;
