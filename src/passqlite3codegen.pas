  end;

  { --- TWhereOrCost (sizeof=16) --- }
  TWhereOrCost = record
    prereq: Bitmask;  { 8 bytes @ 0 }
    rRun:   i16;      { 2 bytes @ 8 (LogEst) }
    nOut:   i16;      { 2 bytes @ 10 (LogEst) }
    _pad:   i32;      { 4 bytes @ 12 }
  end;

  { --- TWhereOrSet (sizeof=56; N_OR_COST=3) --- }
  TWhereOrSet = record
    n:    u16;                         { 2 bytes @ 0 }
    _pad: array[0..5] of u8;           { 6 bytes @ 2 (pad to 8 for Bitmask alignment) }
