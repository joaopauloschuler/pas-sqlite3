  TParseBitsA = record  { bitfields at offset 40 — 9 flags packed into u32 }
    disableTriggers : u32;  { use PARSEFLAG_ constants }
  end;

  TParseU1Cr = record  { u1.cr: isCreate=true }
    addrCrTab:       i32;
    regRowid:        i32;
    regRoot:         i32;
    constraintName:  TToken;  { sizeof(TToken)=16 → total 28 bytes }
  end;

  TParseU1 = record  { union u1 at offset 248, sizeof=32 }
    case Integer of
      0: (cr:         TParseU1Cr);
      1: (pReturning: Pointer);
      2: (_pad:       array[0..31] of u8);
  end;

  TParse = record
    { Offset 0 — main fields (zeroed at start) }
    db:              PTsqlite3;     { 0: database connection }
    zErrMsg:         PAnsiChar;     { 8: error message }
    pVdbe:           PVdbe;         { 16: VDBE under construction }
    rc:              i32;           { 24: return code }
    nQueryLoop:      i16;           { 28: LogEst query loop count }
    nested:          u8;            { 30: nesting depth }
    nTempReg:        u8;            { 31: temp register count }
    isMultiWrite:    u8;            { 32: may modify multiple rows }
    disableLookaside:u8;            { 33: lookaside disable count }
    prepFlags:       u8;            { 34: SQLITE_PREPARE_* flags }
    withinRJSubrtn:  u8;            { 35: nesting for RIGHT JOIN subroutines }
    mSubrtnSig:      u8;            { 36: mini bloom for SubrtnSig }
    eTriggerOp:      u8;            { 37: TK_UPDATE/INSERT/DELETE }
    eOrconf:         u8;            { 38: ON CONFLICT policy }
    _pad39:          u8;            { 39: alignment padding }
    parseFlags:      u32;           { 40: bitfields disableTriggers..checkSchema }
    nRangeReg:       i32;           { 44: size of temp register block }
    iRangeReg:       i32;           { 48: first register in temp block }
    nErr:            i32;           { 52: error count }
    nTab:            i32;           { 56: allocated VDBE cursors }
    nMem:            i32;           { 60: memory cells used }
    szOpAlloc:       i32;           { 64: bytes allocated for Vdbe.aOp[] }
    iSelfTab:        i32;           { 68: table for CHECK constraint }
    nLabel:          i32;           { 72: negative count of labels used }
    nLabelAlloc:     i32;           { 76: slots in aLabel }
    aLabel:          Pi32;          { 80: label address array }
    pConstExpr:      PExprList;     { 88: constant expressions }
    pIdxEpr:         Pointer;       { 96: indexed expressions }
    pIdxPartExpr:    Pointer;       { 104: WHERE clause index exprs }
    writeMask:       u32;           { 112: databases needing write tx }
    cookieMask:      u32;           { 116: schema-verified databases }
    nMaxArg:         i32;           { 120: max vtab method args }
    nSelect:         i32;           { 124: SELECT statement counter }
    nProgressSteps:  u32;           { 128: xProgress steps }
    nTableLock:      i32;           { 132: shared-cache table lock count }
    aTableLock:      Pointer;       { 136: shared-cache table locks }
    pAinc:           Pointer;       { 144: AUTOINCREMENT info }
    pToplevel:       PParse;        { 152: top-level parse (or nil) }
    pTriggerTab:     PTable2;       { 160: table being triggered }
    pTriggerPrg:     Pointer;       { 168: coded triggers list }
    pCleanup:        Pointer;       { 176: cleanup operations }
    aTempReg:        array[0..7] of i32;  { 184: temp register holding area }
    pOuterParse:     PParse;        { 216: outer parse object }
    sNameToken:      TToken;        { 224: unqualified schema object name }
    oldmask:         u32;           { 240: old.* columns referenced }
    newmask:         u32;           { 244: new.* columns referenced }
    u1:              TParseU1;      { 248: CREATE vs other context }
    sLastToken:      TToken;        { 280: last token parsed }
    nVar:            i16;           { 296: '?' variables seen }
    iPkSortOrder:    u8;            { 298: ASC/DESC for INTEGER PRIMARY KEY }
    explain:         u8;            { 299: EXPLAIN flag }
    eParseMode:      u8;            { 300: PARSE_MODE_* }
    _pad301:         array[0..2] of u8;  { 301-303: padding }
    nVtabLock:       i32;           { 304: virtual tables to lock }
    nHeight:         i32;           { 308: expression tree height }
    addrExplain:     i32;           { 312: address of current OP_Explain }
    _pad316:         i32;           { 316: padding }
    pVList:          Pointer;       { 320: variable name-number mapping }
    pReprepare:      PVdbe;         { 328: VM being reprepared }
    zTail:           PAnsiChar;     { 336: SQL text past last semicolon }
    pNewTable:       PTable2;       { 344: table being CREATE'd }
    pNewIndex:       Pointer;       { 352: index being CREATE INDEX'd }
    pNewTrigger:     Pointer;       { 360: trigger under construction }
    zAuthContext:    PAnsiChar;     { 368: 6th param to xAuth callbacks }
    sArg:            TToken;        { 376: vtab module argument text }
    apVtabLock:      Pointer;       { 392: vtabs needing locking }
    pWith:           PWith;         { 400: current WITH clause }
    pRename:         Pointer;       { 408: tokens for ALTER TABLE RENAME }
