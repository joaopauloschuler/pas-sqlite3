{ sqlite3IdListIndex — find index of zName in IdList; -1 if not found }
function sqlite3IdListIndex(pList: PIdList; zName: PAnsiChar): i32;
var
  i:     i32;
  items: PIdListItem;
begin
  if pList = nil then begin Result := -1; Exit; end;
  items := IdListItems(pList);
  for i := 0 to pList^.nId - 1 do
    if sqlite3StrICmp(items[i].zName, zName) = 0 then
    begin
      Result := i; Exit;
    end;
  Result := -1;
end;

{ sqlite3DbReallocOrFree — realloc or free+nil on failure }
function sqlite3DbReallocOrFree(db: PTsqlite3; p: Pointer; n: u64): Pointer;
var pNew: Pointer;
begin
  pNew := sqlite3_realloc64(p, n);
  if pNew = nil then
  begin
    sqlite3DbFree(db, p);
    sqlite3OomFault(db);
  end;
  Result := pNew;
end;


{ sqlite3ProgressCheck — port of util.c:211.  Honour sqlite3_interrupt() and
  invoke the progress callback every nProgressOps statement-compile steps. }
procedure sqlite3ProgressCheck(pParse: PParse);
var
  db: PTsqlite3;
begin
  db := pParse^.db;
  if db^.u1.isInterrupted <> 0 then begin
    Inc(pParse^.nErr);
    pParse^.rc := SQLITE_INTERRUPT;
  end;
  if Assigned(db^.xProgress) then begin
    if pParse^.rc = SQLITE_INTERRUPT then begin
      pParse^.nProgressSteps := 0;
    end else begin
      Inc(pParse^.nProgressSteps);
      if pParse^.nProgressSteps >= db^.nProgressOps then begin
        if db^.xProgress(db^.pProgressArg) <> 0 then begin
          Inc(pParse^.nErr);
          pParse^.rc := SQLITE_INTERRUPT;
        end;
        pParse^.nProgressSteps := 0;
      end;
    end;
  end;
end;

