  { --- TTable (sizeof=120) --- }
  { Union u: tab(24) | view(24) | vtab(24) @ offset 64 }
  TTableUTab = record
    addColOffset: i32;      { 4 bytes @ 0 within union }
    _pad:         i32;      { 4 bytes @ 4 }
