  OPFLAG_P2ISREG       = $10;  { P2 is a register number }
  OPFLAG_PERMUTE       = $01;  { OP_Compare: use permutation }
  OPFLAG_SAVEPOSITION  = $02;  { OP_Delete/Insert: save cursor pos }
  OPFLAG_AUXDELETE     = $04;  { OP_Delete: index in DELETE op }

