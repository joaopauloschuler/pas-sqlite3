    case Integer of
      0: (z: PAnsiChar);
      1: (i: i64);
  end;
  TUnpackedRecord = record
    pKeyInfo:   PKeyInfo2;            { 8 bytes @ 0 }
    aMem:       PMem;                 { 8 bytes @ 8 }
    u:          TUnpackedRecordU;     { 8 bytes @ 16 }
    n:          i32;                  { 4 bytes @ 24 }
    nField:     u16;                  { 2 bytes @ 28 }
    default_rc: i8;                   { 1 byte  @ 30 }
    errCode:    u8;                   { 1 byte  @ 31 }
    r1:         i8;                   { 1 byte  @ 32 }
    r2:         i8;                   { 1 byte  @ 33 }
    eqSeen:     u8;                   { 1 byte  @ 34 }
    _pad35:     array[0..4] of u8;    { 5 bytes @ 35 }
