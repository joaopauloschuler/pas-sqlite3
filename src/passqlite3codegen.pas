    snpFmt(SizeOf(buf), buf, '%02d:%02d:%05.3f', [h2, mn2, s2]);
    sqlite3_result_text(pCtx, buf, -1, SQLITE_TRANSIENT);
    Exit;
  end;
  z := sqlite3_value_text(Psqlite3_value(argv^));
