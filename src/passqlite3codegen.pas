procedure sqlite3DequoteExpr(p: PExpr);
begin
  if p = nil then Exit;
  if ExprHasProperty(p, EP_IntValue) then Exit;
  if p^.u.zToken = nil then Exit;
  if not (p^.u.zToken[0] in ['"', '''', '[', '`']) then Exit;
  p^.flags := p^.flags or u32(EP_Quoted);
  if p^.u.zToken[0] = '"' then
    p^.flags := p^.flags or u32(EP_DblQuoted);
  sqlite3Dequote(p^.u.zToken);
end;

