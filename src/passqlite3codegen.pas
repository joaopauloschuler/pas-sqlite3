    sqlite3FindFunction's matchQuality treats negative nArg as variadic. }
  MakeFD(aBuiltinFuncs[49], -3, FUNC_ENC, @concatFunc,   nil, 'concat');
  MakeFD(aBuiltinFuncs[50], -4, FUNC_ENC, @concatwsFunc, nil, 'concat_ws');
