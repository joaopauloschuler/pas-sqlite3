{ Height helpers (local) }
procedure heightOfExpr_(const p: PExpr; pnHeight: Pi32);
begin
  if (p <> nil) and (p^.nHeight > pnHeight^) then
    pnHeight^ := p^.nHeight;
end;

procedure heightOfExprList_(const p: PExprList; pnHeight: Pi32);
var i: i32; pItem: PExprListItem;
begin
  if p <> nil then
  begin
    pItem := ExprListItems(p);
    for i := 0 to p^.nExpr - 1 do
    begin
      heightOfExpr_(pItem^.pExpr, pnHeight);
      Inc(pItem);
    end;
  end;
end;

procedure heightOfSelect_(const pSel: PSelect; pnHeight: Pi32);
var p: PSelect;
begin
  p := pSel;
  while p <> nil do
  begin
    heightOfExpr_(p^.pWhere,   pnHeight);
    heightOfExpr_(p^.pHaving,  pnHeight);
    heightOfExpr_(p^.pLimit,   pnHeight);
    heightOfExprList_(p^.pEList,   pnHeight);
    heightOfExprList_(p^.pGroupBy, pnHeight);
    heightOfExprList_(p^.pOrderBy, pnHeight);
    p := p^.pPrior;
  end;
end;

procedure exprSetHeight_(p: PExpr);
var nHeight: i32;
begin
  nHeight := 0;
  if p^.pLeft <> nil then nHeight := p^.pLeft^.nHeight;
  if (p^.pRight <> nil) and (p^.pRight^.nHeight > nHeight) then
    nHeight := p^.pRight^.nHeight;
  if ExprUseXSelect(p) then
    heightOfSelect_(p^.x.pSelect, @nHeight)
  else if p^.x.pList <> nil then
  begin
    heightOfExprList_(p^.x.pList, @nHeight);
    p^.flags := p^.flags or (EP_Propagate and sqlite3ExprListFlags(p^.x.pList));
  end;
  p^.nHeight := nHeight + 1;
end;

function sqlite3ExprCheckHeight(pParse: PParse; nHeight: i32): i32;
var mxHeight: i32;
begin
  Result := SQLITE_OK;
  if nHeight > SQLITE_MAX_EXPR_DEPTH then
  begin
    mxHeight := SQLITE_MAX_EXPR_DEPTH;
    if pParse <> nil then
    begin
      if pParse^.db <> nil then
        mxHeight := pParse^.db^.aLimit[SQLITE_LIMIT_EXPR_DEPTH];
      if nHeight > mxHeight then
      begin
        sqlite3ErrorMsg(pParse, 'Expression tree is too large');
        Result := SQLITE_ERROR;
      end;
    end;
  end;
end;

procedure sqlite3ExprSetHeightAndFlags(pParse: PParse; p: PExpr);
begin
  if (pParse <> nil) and (pParse^.nErr > 0) then Exit;
  if p = nil then Exit;
  exprSetHeight_(p);
  if pParse <> nil then
    sqlite3ExprCheckHeight(pParse, p^.nHeight);
end;

function sqlite3SelectExprHeight(const p: PSelect): i32;
var nHeight: i32;
begin
  nHeight := 0;
  heightOfSelect_(p, @nHeight);
  Result := nHeight;
end;

procedure sqlite3ExprSetErrorOffset(pExpr: PExpr; iOfst: i32);
begin
  if pExpr = nil then Exit;
  if (pExpr^.flags and (EP_InnerON or EP_OuterON)) <> 0 then Exit;
  pExpr^.w.iOfst := iOfst;
end;

{ expr.c ~931: sqlite3ExprAlloc }
function sqlite3ExprAlloc(db: PTsqlite3; op: i32;
  const pToken: PToken; dequote: i32): PExpr;
var
  pNew:   PExpr;
  nExtra: i32;
begin
  if pToken <> nil then nExtra := i32(pToken^.n) + 1 else nExtra := 0;
  pNew := PExpr(sqlite3DbMallocRawNN(db, SizeOf(TExpr) + nExtra));
  if pNew <> nil then
  begin
    FillChar(pNew^, SizeOf(TExpr), 0);
    pNew^.op   := u8(op);
    pNew^.iAgg := -1;
    if nExtra > 0 then
    begin
      pNew^.u.zToken := PAnsiChar(PByte(pNew) + SizeOf(TExpr));
      if (pToken^.n > 0) and (pToken^.z <> nil) then
        Move(pToken^.z^, pNew^.u.zToken^, pToken^.n);
      pNew^.u.zToken[pToken^.n] := #0;
      if (dequote <> 0) and (pNew^.u.zToken[0] in ['"', '''', '[', '`']) then
        sqlite3DequoteExpr(pNew);
    end;
    pNew^.nHeight := 1;
  end;
  Result := pNew;
end;

{ expr.c ~967: sqlite3Expr }
function sqlite3Expr(db: PTsqlite3; op: i32; zToken: PAnsiChar): PExpr;
var tok: TToken;
begin
  tok.z := zToken;
  if zToken <> nil then tok.n := u32(sqlite3Strlen30(zToken))
  else tok.n := 0;
  Result := sqlite3ExprAlloc(db, op, @tok, 0);
end;

{ expr.c ~981: sqlite3ExprInt32 }
function sqlite3ExprInt32(db: PTsqlite3; iVal: i32): PExpr;
var pNew: PExpr;
begin
  pNew := PExpr(sqlite3DbMallocRawNN(db, SizeOf(TExpr)));
  if pNew <> nil then
  begin
    FillChar(pNew^, SizeOf(TExpr), 0);
    pNew^.op   := TK_INTEGER;
    pNew^.iAgg := -1;
    if iVal <> 0 then
      pNew^.flags := EP_IntValue or EP_Leaf or EP_IsTrue
    else
      pNew^.flags := EP_IntValue or EP_Leaf or EP_IsFalse;
    pNew^.u.iValue := iVal;
    pNew^.nHeight  := 1;
  end;
  Result := pNew;
end;

{ expr.c ~1002: sqlite3ExprAttachSubtrees }
procedure sqlite3ExprAttachSubtrees(db: PTsqlite3; pRoot: PExpr;
  pLeft: PExpr; pRight: PExpr);
begin
  if pRoot = nil then
  begin
    sqlite3ExprDelete(db, pLeft);
    sqlite3ExprDelete(db, pRight);
    Exit;
  end;
  if pRight <> nil then
  begin
    pRoot^.pRight := pRight;
    pRoot^.flags  := pRoot^.flags or (EP_Propagate and pRight^.flags);
    if pRight^.nHeight + 1 > pRoot^.nHeight then
      pRoot^.nHeight := pRight^.nHeight + 1;
  end else
    pRoot^.nHeight := 1;
  if pLeft <> nil then
  begin
    pRoot^.pLeft := pLeft;
    pRoot^.flags := pRoot^.flags or (EP_Propagate and pLeft^.flags);
    if pLeft^.nHeight >= pRoot^.nHeight then
      pRoot^.nHeight := pLeft^.nHeight + 1;
  end;
end;

{ expr.c ~1043: sqlite3PExpr }
function sqlite3PExpr(pParse: PParse; op: i32;
  pLeft: PExpr; pRight: PExpr): PExpr;
var p: PExpr;
begin
  p := PExpr(sqlite3DbMallocRawNN(pParse^.db, SizeOf(TExpr)));
  if p <> nil then
  begin
    FillChar(p^, SizeOf(TExpr), 0);
    p^.op   := u8(op and $ff);
    p^.iAgg := -1;
    sqlite3ExprAttachSubtrees(pParse^.db, p, pLeft, pRight);
    sqlite3ExprCheckHeight(pParse, p^.nHeight);
  end else
  begin
    sqlite3ExprDelete(pParse^.db, pLeft);
    sqlite3ExprDelete(pParse^.db, pRight);
  end;
  Result := p;
end;

{ expr.c ~1068: sqlite3PExprAddSelect }
procedure sqlite3PExprAddSelect(pParse: PParse; pExpr: PExpr; pSelect: PSelect);
begin
  if pExpr <> nil then
  begin
    pExpr^.x.pSelect := pSelect;
    pExpr^.flags     := pExpr^.flags or (EP_xIsSelect or EP_Subquery);
    sqlite3ExprSetHeightAndFlags(pParse, pExpr);
  end else
    sqlite3SelectDelete(pParse^.db, pSelect);
end;

{ expr.c ~1145: sqlite3ExprAnd }
function sqlite3ExprAnd(pParse: PParse; pLeft: PExpr; pRight: PExpr): PExpr;
var
  db: PTsqlite3;
  f:  u32;
begin
  db := pParse^.db;
  if pLeft = nil then begin Result := pRight; Exit; end;
  if pRight = nil then begin Result := pLeft; Exit; end;
  f := pLeft^.flags or pRight^.flags;
  if ((f and (EP_OuterON or EP_InnerON or EP_IsFalse or EP_HasFunc)) = EP_IsFalse)
     and not InRenameObject(pParse) then
  begin
    sqlite3ExprDeferredDelete(pParse, pLeft);
    sqlite3ExprDeferredDelete(pParse, pRight);
    Result := sqlite3ExprInt32(db, 0);
  end else
    Result := sqlite3PExpr(pParse, TK_AND, pLeft, pRight);
end;

{ expr.c ~1387: sqlite3ExprDeleteNN (recursive tree deletion) }
procedure sqlite3ExprDeleteNN(db: PTsqlite3; p: PExpr);
label exprDeleteRestart;
var pLeft: PExpr;
begin
  if p = nil then Exit;
exprDeleteRestart:
  if not ExprHasProperty(p, EP_TokenOnly or EP_Leaf) then
  begin
    if p^.pRight <> nil then
      sqlite3ExprDeleteNN(db, p^.pRight)
    else if ExprUseXSelect(p) then
      sqlite3SelectDelete(db, p^.x.pSelect)
    else
    begin
      sqlite3ExprListDelete(db, p^.x.pList);
      if ExprHasProperty(p, EP_WinFunc) then
        sqlite3WindowDelete(db, p^.y.pWin);
    end;
    if (p^.pLeft <> nil) and (p^.op <> TK_SELECT_COLUMN) then
    begin
      pLeft := p^.pLeft;
      if not ExprHasProperty(p, EP_Static)
         and not ExprHasProperty(pLeft, EP_Static) then
      begin
        sqlite3DbNNFreeNN(db, p);
        p := pLeft;
        goto exprDeleteRestart;
      end else
        sqlite3ExprDeleteNN(db, pLeft);
    end;
  end;
  if not ExprHasProperty(p, EP_Static) then
    sqlite3DbNNFreeNN(db, p);
end;

procedure sqlite3ExprDelete(db: PTsqlite3; p: PExpr);
begin
  if p <> nil then sqlite3ExprDeleteNN(db, p);
end;

procedure sqlite3ExprDeleteGeneric(db: PTsqlite3; p: Pointer);
begin
  if p <> nil then sqlite3ExprDeleteNN(db, PExpr(p));
end;

{ expr.c ~1448: sqlite3ClearOnOrUsing }
procedure sqlite3ClearOnOrUsing(db: PTsqlite3; p: POnOrUsing);
begin
  if p = nil then Exit;
  if p^.pOn <> nil then
    sqlite3ExprDeleteNN(db, p^.pOn)
  else if p^.pUsing <> nil then
    sqlite3IdListDelete(db, p^.pUsing);
end;

{ expr.c ~1468: sqlite3ExprDeferredDelete }
function sqlite3ExprDeferredDelete(pParse: PParse; pExpr: PExpr): i32;
begin
  Result := ord(nil = sqlite3ParserAddCleanup(pParse, @sqlite3ExprDeleteGeneric, pExpr));
end;

{ expr.c ~1475: sqlite3ExprUnmapAndDelete }
procedure sqlite3ExprUnmapAndDelete(pParse: PParse; p: PExpr);
begin
  if p <> nil then
  begin
    if InRenameObject(pParse) then
      sqlite3RenameExprUnmap(pParse, p);
    sqlite3ExprDeleteNN(pParse^.db, p);
  end;
end;

{ IdList deletion }
procedure sqlite3IdListDelete(db: PTsqlite3; pList: PIdList);
var i: i32; pItem: PIdListItem;
begin
  if pList = nil then Exit;
  pItem := IdListItems(pList);
  for i := 0 to pList^.nId - 1 do
  begin
    sqlite3DbFree(db, pItem^.zName);
    Inc(pItem);
  end;
  sqlite3DbFree(db, pList);
end;

{ SrcList deletion }
procedure sqlite3SrcListDelete(db: PTsqlite3; pList: PSrcList);
var
  i:    i32;
  pItem: PSrcItem;
begin
  if pList = nil then Exit;
  pItem := SrcListItems(pList);
  for i := 0 to pList^.nSrc - 1 do
  begin
    sqlite3DbFree(db, pItem^.zName);
    sqlite3DbFree(db, pItem^.zAlias);
    if SrcItemIsSubquery(pItem^.fg) and (pItem^.u4.pSubq <> nil) then
    begin
      sqlite3SelectDelete(db, pItem^.u4.pSubq^.pSelect);
      sqlite3DbFree(db, pItem^.u4.pSubq);
    end else if (pItem^.fg.fgBits and SRCITEM_FG_IS_INDEXED_BY) <> 0 then
      sqlite3DbFree(db, pItem^.u1.zIndexedBy)
    else if SrcItemIsTabFunc(pItem^.fg) then
      sqlite3ExprListDelete(db, pItem^.u1.pFuncArg);
    { u3: on/using }
    if (pItem^.fg.fgBits2 and $08) <> 0 then  { isUsing bit }
      sqlite3IdListDelete(db, pItem^.u3.pUsing)
    else
      sqlite3ExprDelete(db, pItem^.u3.pOn);
    Inc(pItem);
  end;
  sqlite3DbFree(db, pList);
end;

{ expr.c: ExprList deletion }
procedure exprListDeleteNN_(db: PTsqlite3; pList: PExprList);
var
  i:     i32;
  pItem: PExprListItem;
begin
  pItem := ExprListItems(pList);
  i := pList^.nExpr;
  repeat
    sqlite3ExprDelete(db, pItem^.pExpr);
    if pItem^.zEName <> nil then
      sqlite3DbNNFreeNN(db, pItem^.zEName);
    Inc(pItem);
    Dec(i);
  until i = 0;
  sqlite3DbNNFreeNN(db, pList);
end;

procedure sqlite3ExprListDelete(db: PTsqlite3; pList: PExprList);
begin
  if pList <> nil then exprListDeleteNN_(db, pList);
end;

procedure sqlite3ExprListDeleteGeneric(db: PTsqlite3; pList: Pointer);
begin
  if pList <> nil then exprListDeleteNN_(db, PExprList(pList));
end;

function sqlite3ExprListFlags(const pList: PExprList): u32;
var
  i:     i32;
  m:     u32;
  pItem: PExprListItem;
begin
  m := 0;
  if pList <> nil then
  begin
    pItem := ExprListItems(pList);
    for i := 0 to pList^.nExpr - 1 do
    begin
      if pItem^.pExpr <> nil then m := m or pItem^.pExpr^.flags;
      Inc(pItem);
    end;
  end;
  Result := m;
end;

{ Internal helpers for exprDup_ }
function dupedExprStructSize_(const p: PExpr; flags: i32): i32;
begin
  if (flags = 0) or ExprHasProperty(p, EP_FullSize) then
    Result := EXPR_FULLSIZE
  else if (p^.pLeft <> nil) or (p^.x.pList <> nil) then
    Result := EXPR_REDUCEDSIZE or i32(EP_Reduced)
  else
    Result := EXPR_TOKENONLYSIZE or i32(EP_TokenOnly);
end;

function dupedExprNodeSize_(const p: PExpr; flags: i32): i32;
var n: i32;
begin
  n := dupedExprStructSize_(p, flags) and $fff;
  if not ExprHasProperty(p, EP_IntValue) and (p^.u.zToken <> nil) then
    Inc(n, sqlite3Strlen30NN(p^.u.zToken) + 1);
  Result := ROUND8(n);
end;

function dupedExprSize_(const p: PExpr): i32;
var n: i32;
begin
  n := dupedExprNodeSize_(p, EXPRDUP_REDUCE);
  if p^.pLeft <> nil then Inc(n, dupedExprSize_(p^.pLeft));
  if p^.pRight <> nil then Inc(n, dupedExprSize_(p^.pRight));
  Result := ROUND8(n);
end;

function exprStructSize_(const p: PExpr): i32;
begin
  if ExprHasProperty(p, EP_TokenOnly) then Result := EXPR_TOKENONLYSIZE
  else if ExprHasProperty(p, EP_Reduced) then Result := EXPR_REDUCEDSIZE
  else Result := EXPR_FULLSIZE;
end;

type TEdupBuf = record zAlloc: PByte; end;

function exprDup_(db: PTsqlite3; const p: PExpr; dupFlags: i32;
  pEdupBuf: Pointer): PExpr; forward;

function exprDup_(db: PTsqlite3; const p: PExpr; dupFlags: i32;
  pEdupBuf: Pointer): PExpr;
var
  pNew:       PExpr;
  sEdupBuf:   TEdupBuf;
  staticFlag: u32;
  nToken:     i32;
  nStructSize:i32;
  nNewSize:   i32;
  nAlloc:     i32;
  zToken:     PAnsiChar;
begin
  nToken := -1;
  if pEdupBuf <> nil then
  begin
    sEdupBuf.zAlloc := TEdupBuf(pEdupBuf^).zAlloc;
    staticFlag := EP_Static;
  end else
  begin
    if dupFlags <> 0 then
      nAlloc := dupedExprSize_(p)
    else if not ExprHasProperty(p, EP_IntValue) and (p^.u.zToken <> nil) then
    begin
      nToken := sqlite3Strlen30NN(p^.u.zToken) + 1;
      nAlloc := ROUND8(EXPR_FULLSIZE + nToken);
    end else
    begin
      nToken := 0;
      nAlloc := ROUND8(EXPR_FULLSIZE);
    end;
    sEdupBuf.zAlloc := PByte(sqlite3DbMallocRawNN(db, nAlloc));
    staticFlag := 0;
  end;

  pNew := PExpr(sEdupBuf.zAlloc);
  if pNew = nil then begin Result := nil; Exit; end;

  nStructSize := dupedExprStructSize_(p, dupFlags);
  nNewSize    := nStructSize and $fff;
  if nToken < 0 then
  begin
    if not ExprHasProperty(p, EP_IntValue) and (p^.u.zToken <> nil) then
      nToken := sqlite3Strlen30(p^.u.zToken) + 1
    else
      nToken := 0;
  end;

  if dupFlags <> 0 then
    Move(p^, sEdupBuf.zAlloc^, nNewSize)
  else
  begin
    nAlloc := exprStructSize_(p);
    Move(p^, sEdupBuf.zAlloc^, nAlloc);
    if nAlloc < EXPR_FULLSIZE then
      FillChar((sEdupBuf.zAlloc + nAlloc)^, EXPR_FULLSIZE - nAlloc, 0);
    nNewSize := EXPR_FULLSIZE;
  end;

  pNew^.flags := (pNew^.flags and not u32(EP_Reduced or EP_TokenOnly or EP_Static))
                  or u32(nStructSize and i32(EP_Reduced or EP_TokenOnly))
                  or staticFlag;

  if nToken > 0 then
  begin
    zToken := PAnsiChar(sEdupBuf.zAlloc + nNewSize);
    pNew^.u.zToken := zToken;
    Move(p^.u.zToken^, zToken^, nToken);
    Inc(nNewSize, nToken);
  end;
  Inc(sEdupBuf.zAlloc, ROUND8(nNewSize));

  if ((p^.flags or pNew^.flags) and u32(EP_TokenOnly or EP_Leaf)) = 0 then
  begin
    if ExprUseXSelect(p) then
      pNew^.x.pSelect := sqlite3SelectDup(db, p^.x.pSelect, dupFlags)
    else
      if p^.op <> TK_ORDER then
        pNew^.x.pList := sqlite3ExprListDup(db, p^.x.pList, dupFlags)
      else
        pNew^.x.pList := sqlite3ExprListDup(db, p^.x.pList, 0);

    if ExprHasProperty(p, EP_WinFunc) then
      pNew^.y.pWin := sqlite3WindowDup(db, pNew, p^.y.pWin);

    if dupFlags <> 0 then
    begin
      if p^.op = TK_SELECT_COLUMN then
        pNew^.pLeft := p^.pLeft
      else
        pNew^.pLeft := exprDup_(db, p^.pLeft, EXPRDUP_REDUCE, @sEdupBuf);
      pNew^.pRight := exprDup_(db, p^.pRight, EXPRDUP_REDUCE, @sEdupBuf);
    end else
    begin
      if p^.op = TK_SELECT_COLUMN then
        pNew^.pLeft := p^.pLeft
      else
        pNew^.pLeft := sqlite3ExprDup(db, p^.pLeft, 0);
      pNew^.pRight := sqlite3ExprDup(db, p^.pRight, 0);
    end;
  end;

  if pEdupBuf <> nil then
    TEdupBuf(pEdupBuf^).zAlloc := sEdupBuf.zAlloc;
  Result := pNew;
end;

function sqlite3ExprDup(db: PTsqlite3; const p: PExpr; flags: i32): PExpr;
begin
  if p = nil then Result := nil
  else Result := exprDup_(db, p, flags, nil);
end;

function sqlite3ExprListDup(db: PTsqlite3; const p: PExprList;
  flags: i32): PExprList;
var
  pNew:               PExprList;
  pItem:              PExprListItem;
  pOldItem:           PExprListItem;
  pPriorSelectColOld: PExpr;
  pPriorSelectColNew: PExpr;
  pOldExpr:           PExpr;
  pNewExpr:           PExpr;
  i:                  i32;
  nByte:              i32;
begin
  if p = nil then begin Result := nil; Exit; end;
  nByte := SZ_EXPRLIST_HEADER + p^.nAlloc * SZ_EXPRLIST_ITEM;
  pNew := PExprList(sqlite3DbMallocRawNN(db, nByte));
  if pNew = nil then begin Result := nil; Exit; end;
  pNew^.nExpr  := p^.nExpr;
  pNew^.nAlloc := p^.nAlloc;
  pItem    := ExprListItems(pNew);
  pOldItem := ExprListItems(p);
  pPriorSelectColOld := nil;
  pPriorSelectColNew := nil;
  for i := 0 to p^.nExpr - 1 do
  begin
    pOldExpr := pOldItem^.pExpr;
    pItem^.pExpr := sqlite3ExprDup(db, pOldExpr, flags);
    if (pOldExpr <> nil) and (pOldExpr^.op = TK_SELECT_COLUMN) then
    begin
      pNewExpr := pItem^.pExpr;
      if pNewExpr <> nil then
      begin
        if pNewExpr^.pRight <> nil then
        begin
          pPriorSelectColOld := pOldExpr^.pRight;
          pPriorSelectColNew := pNewExpr^.pRight;
          pNewExpr^.pLeft    := pNewExpr^.pRight;
        end else
        begin
          if pOldExpr^.pLeft <> pPriorSelectColOld then
          begin
            pPriorSelectColOld := pOldExpr^.pLeft;
            pPriorSelectColNew := sqlite3ExprDup(db, pPriorSelectColOld, flags);
            pNewExpr^.pRight   := pPriorSelectColNew;
          end;
          pNewExpr^.pLeft := pPriorSelectColNew;
        end;
      end;
    end;
    pItem^.zEName := sqlite3DbStrDup(db, pOldItem^.zEName);
    pItem^.fg     := pOldItem^.fg;
    pItem^.u      := pOldItem^.u;
    Inc(pItem);
    Inc(pOldItem);
  end;
  Result := pNew;
end;

function sqlite3SrcListDup(db: PTsqlite3; const p: PSrcList;
  flags: i32): PSrcList;
var
  pNew:     PSrcList;
  pNewItem: PSrcItem;
  pOldItem: PSrcItem;
  pNewSubq: PSubquery;
  i:        i32;
begin
  if p = nil then begin Result := nil; Exit; end;
  pNew := PSrcList(sqlite3DbMallocRawNN(db,
    SZ_SRCLIST_HEADER + p^.nSrc * SZ_SRCLIST_ITEM));
  if pNew = nil then begin Result := nil; Exit; end;
  pNew^.nSrc   := p^.nSrc;
  pNew^.nAlloc := u32(p^.nSrc);
  pNewItem := SrcListItems(pNew);
  pOldItem := SrcListItems(p);
  for i := 0 to p^.nSrc - 1 do
  begin
    pNewItem^.fg   := pOldItem^.fg;
    if SrcItemIsSubquery(pOldItem^.fg) then
    begin
      pNewSubq := PSubquery(sqlite3DbMallocRaw(db, SizeOf(TSubquery)));
      if pNewSubq = nil then
        pNewItem^.fg.fgBits := pNewItem^.fg.fgBits and not SRCITEM_FG_IS_SUBQUERY
      else
      begin
        pNewSubq^ := pOldItem^.u4.pSubq^;
        pNewSubq^.pSelect := sqlite3SelectDup(db, pNewSubq^.pSelect, flags);
        if pNewSubq^.pSelect = nil then
        begin
          sqlite3DbFree(db, pNewSubq);
          pNewSubq := nil;
          pNewItem^.fg.fgBits := pNewItem^.fg.fgBits and not SRCITEM_FG_IS_SUBQUERY;
        end;
      end;
      pNewItem^.u4.pSubq := pNewSubq;
    end else if (pOldItem^.fg.fgBits3 and $01) <> 0 then  { fixedSchema }
      pNewItem^.u4.pSchema := pOldItem^.u4.pSchema
    else
      pNewItem^.u4.zDatabase := sqlite3DbStrDup(db, pOldItem^.u4.zDatabase);
    pNewItem^.zName  := sqlite3DbStrDup(db, pOldItem^.zName);
    pNewItem^.zAlias := sqlite3DbStrDup(db, pOldItem^.zAlias);
    pNewItem^.iCursor := pOldItem^.iCursor;
    if (pOldItem^.fg.fgBits and SRCITEM_FG_IS_INDEXED_BY) <> 0 then
      pNewItem^.u1.zIndexedBy := sqlite3DbStrDup(db, pOldItem^.u1.zIndexedBy)
    else if SrcItemIsTabFunc(pOldItem^.fg) then
      pNewItem^.u1.pFuncArg :=
        sqlite3ExprListDup(db, pOldItem^.u1.pFuncArg, flags)
    else
      pNewItem^.u1.nRow := pOldItem^.u1.nRow;
    pNewItem^.u2 := pOldItem^.u2;
    if (pOldItem^.fg.fgBits2 and $08) <> 0 then  { isUsing }
      pNewItem^.u3.pUsing := sqlite3IdListDup(db, pOldItem^.u3.pUsing)
    else
      pNewItem^.u3.pOn := sqlite3ExprDup(db, pOldItem^.u3.pOn, flags);
    pNewItem^.colUsed := pOldItem^.colUsed;
    Inc(pNewItem);
    Inc(pOldItem);
  end;
  Result := pNew;
end;

function sqlite3IdListDup(db: PTsqlite3; const p: PIdList): PIdList;
var
  pNew:     PIdList;
  pNewItem: PIdListItem;
  pOldItem: PIdListItem;
  i:        i32;
begin
  if p = nil then begin Result := nil; Exit; end;
  pNew := PIdList(sqlite3DbMallocRawNN(db, SZ_IDLIST_HEADER + p^.nId * SZ_IDLIST_ITEM));
  if pNew = nil then begin Result := nil; Exit; end;
  pNew^.nId := p^.nId;
  pNewItem := IdListItems(pNew);
  pOldItem := IdListItems(p);
  for i := 0 to p^.nId - 1 do
  begin
    pNewItem^.zName := sqlite3DbStrDup(db, pOldItem^.zName);
    Inc(pNewItem);
    Inc(pOldItem);
  end;
  Result := pNew;
end;

function sqlite3SelectDup(db: PTsqlite3; const pDup: PSelect; flags: i32): PSelect;
var
  pRet:  PSelect;
  pNext: PSelect;
  pp:    ^PSelect;
  p:     PSelect;
  pNew:  PSelect;
begin
  pRet  := nil;
  pNext := nil;
  pp    := @pRet;
  p     := pDup;
  while p <> nil do
  begin
    pNew := PSelect(sqlite3DbMallocRawNN(db, SizeOf(TSelect)));
    if pNew = nil then Break;
    pNew^.pEList   := sqlite3ExprListDup(db, p^.pEList, flags);
    pNew^.pSrc     := sqlite3SrcListDup(db, p^.pSrc, flags);
    pNew^.pWhere   := sqlite3ExprDup(db, p^.pWhere, flags);
    pNew^.pGroupBy := sqlite3ExprListDup(db, p^.pGroupBy, flags);
    pNew^.pHaving  := sqlite3ExprDup(db, p^.pHaving, flags);
    pNew^.pOrderBy := sqlite3ExprListDup(db, p^.pOrderBy, flags);
    pNew^.op       := p^.op;
    pNew^.pNext    := pNext;
    pNew^.pPrior   := nil;
    pNew^.pLimit   := sqlite3ExprDup(db, p^.pLimit, flags);
    pNew^.iLimit   := 0;
    pNew^.iOffset  := 0;
    pNew^.selFlags := p^.selFlags;
    pNew^.nSelectRow := p^.nSelectRow;
    pNew^.pWith    := nil;  { Phase 6.5 }
    pNew^.pWin     := nil;
    pNew^.pWinDefn := sqlite3WindowListDup(db, p^.pWinDefn);
    pNew^.selId    := p^.selId;
    if db^.mallocFailed <> 0 then
    begin
      pNew^.pNext := nil;
      sqlite3SelectDelete(db, pNew);
      Break;
    end;
    pp^  := pNew;
    pp   := @pNew^.pPrior;
    pNext := pNew;
    p    := p^.pPrior;
  end;
  Result := pRet;
end;

{ expr.c ~2024: sqlite3ExprListAppendNew }
function sqlite3ExprListAppendNew(db: PTsqlite3; pExpr: PExpr): PExprList;
var
  pList: PExprList;
  pItem: PExprListItem;
begin
  pList := PExprList(sqlite3DbMallocRawNN(db,
    SZ_EXPRLIST_HEADER + 4 * SZ_EXPRLIST_ITEM));
  if pList = nil then
  begin
    sqlite3ExprDelete(db, pExpr);
    Result := nil;
    Exit;
  end;
  pList^.nAlloc := 4;
  pList^.nExpr  := 1;
  pItem := ExprListItems(pList);
  FillChar(pItem^, SizeOf(TExprListItem), 0);
  pItem^.pExpr := pExpr;
  Result := pList;
end;

{ expr.c ~2043: sqlite3ExprListAppendGrow }
function sqlite3ExprListAppendGrow(db: PTsqlite3; pList: PExprList;
  pExpr: PExpr): PExprList;
var
  pNew:  PExprList;
  pItem: PExprListItem;
begin
  pList^.nAlloc := pList^.nAlloc * 2;
  pNew := PExprList(sqlite3DbRealloc(db, pList,
    SZ_EXPRLIST_HEADER + pList^.nAlloc * SZ_EXPRLIST_ITEM));
  if pNew = nil then
  begin
    sqlite3ExprListDelete(db, pList);
    sqlite3ExprDelete(db, pExpr);
    Result := nil;
    Exit;
  end;
  pList := pNew;
  pItem := PExprListItem(PByte(ExprListItems(pList)) +
    pList^.nExpr * SZ_EXPRLIST_ITEM);
  FillChar(pItem^, SizeOf(TExprListItem), 0);
  pItem^.pExpr := pExpr;
  Inc(pList^.nExpr);
  Result := pList;
end;

{ expr.c ~2064: sqlite3ExprListAppend }
function sqlite3ExprListAppend(pParse: PParse; pList: PExprList;
  pExpr: PExpr): PExprList;
var pItem: PExprListItem;
begin
  if pList = nil then
  begin
    Result := sqlite3ExprListAppendNew(pParse^.db, pExpr);
    Exit;
  end;
  if pList^.nAlloc < pList^.nExpr + 1 then
  begin
    Result := sqlite3ExprListAppendGrow(pParse^.db, pList, pExpr);
    Exit;
  end;
  pItem := PExprListItem(PByte(ExprListItems(pList)) +
    pList^.nExpr * SZ_EXPRLIST_ITEM);
  FillChar(pItem^, SizeOf(TExprListItem), 0);
  pItem^.pExpr := pExpr;
  Inc(pList^.nExpr);
  Result := pList;
end;

procedure sqlite3ExprListSetSortOrder(p: PExprList; iSortOrder: i32; eNulls: i32);
var pItem: PExprListItem;
begin
  if p = nil then Exit;
  pItem := PExprListItem(PByte(ExprListItems(p)) +
    (p^.nExpr - 1) * SZ_EXPRLIST_ITEM);
  if iSortOrder = SQLITE_SO_UNDEFINED then iSortOrder := SQLITE_SO_ASC;
  pItem^.fg.sortFlags := u8(iSortOrder);
  if eNulls <> SQLITE_SO_UNDEFINED then
  begin
    pItem^.fg.eBits := pItem^.fg.eBits or $20;  { bNulls bit }
    if iSortOrder <> eNulls then
      pItem^.fg.sortFlags := pItem^.fg.sortFlags or KEYINFO_ORDER_BIGNULL;
  end;
end;

procedure sqlite3ExprListSetName(pParse: PParse; pList: PExprList;
  const pName: PToken; dequote: i32);
var pItem: PExprListItem;
begin
  if pList = nil then Exit;
  pItem := PExprListItem(PByte(ExprListItems(pList)) +
    (pList^.nExpr - 1) * SZ_EXPRLIST_ITEM);
  pItem^.zEName := sqlite3DbStrNDup(pParse^.db, pName^.z, u64(pName^.n));
  if dequote <> 0 then
  begin
    sqlite3Dequote(pItem^.zEName);
    if InRenameObject(pParse) then
      sqlite3RenameTokenMap(pParse, pItem^.zEName, pName);
  end;
end;

procedure sqlite3ExprListCheckLength(pParse: PParse; pEList: PExprList;
  zObject: PAnsiChar);
var mx: i32;
begin
  if pEList = nil then Exit;
  mx := SQLITE_MAX_COLUMN;
  if pParse^.db <> nil then
    mx := pParse^.db^.aLimit[SQLITE_LIMIT_COLUMN];
  if pEList^.nExpr > mx then
    sqlite3ErrorMsg(pParse, 'too many columns');
end;

{ expr.c: affinity helpers }
function sqlite3TableColumnAffinity(pTab: PTable2; iCol: i32): AnsiChar;
begin
  Result := AnsiChar(SQLITE_AFF_INTEGER);  { default for Phase 6.1 }
  { Full implementation requires Column struct (Phase 6.5) }
end;

function sqlite3ExprAffinity(const pExpr: PExpr): AnsiChar;
var
  op:  i32;
  p:   PExpr;
  pEl: PExprListItem;
begin
  p := pExpr;
  op := p^.op;
  while True do
  begin
    if (op = TK_COLUMN) or ((op = TK_AGG_COLUMN) and (p^.y.pTab <> nil)) then
    begin
      Result := sqlite3TableColumnAffinity(p^.y.pTab, p^.iColumn);
      Exit;
    end;
    if op = TK_SELECT then
    begin
      if (p^.x.pSelect <> nil) and (p^.x.pSelect^.pEList <> nil)
         and (ExprListItems(p^.x.pSelect^.pEList)^.pExpr <> nil) then
        Result := sqlite3ExprAffinity(ExprListItems(p^.x.pSelect^.pEList)^.pExpr)
      else
        Result := AnsiChar(SQLITE_AFF_BLOB);
      Exit;
    end;
    if op = TK_CAST then
    begin
      if not ExprHasProperty(p, EP_IntValue) then
        Result := sqlite3AffinityType(p^.u.zToken, nil)
      else
        Result := AnsiChar(SQLITE_AFF_BLOB);
      Exit;
    end;
    if op = TK_SELECT_COLUMN then
    begin
      if (p^.pLeft <> nil) and ExprUseXSelect(p^.pLeft)
         and (p^.iColumn < p^.iTable) then
      begin
        pEl := PExprListItem(PByte(ExprListItems(p^.pLeft^.x.pSelect^.pEList))
          + p^.iColumn * SZ_EXPRLIST_ITEM);
        if pEl^.pExpr <> nil then
          Result := sqlite3ExprAffinity(pEl^.pExpr)
        else
          Result := AnsiChar(SQLITE_AFF_BLOB);
        Exit;
      end;
      Result := AnsiChar(SQLITE_AFF_BLOB);
      Exit;
    end;
    if (op = TK_VECTOR) or
       ((op = TK_FUNCTION) and (p^.affExpr = AnsiChar(SQLITE_AFF_DEFER))) then
    begin
      if not ExprUseXList(p) or (p^.x.pList = nil) then
      begin Result := AnsiChar(SQLITE_AFF_BLOB); Exit; end;
      Result := sqlite3ExprAffinity(ExprListItems(p^.x.pList)^.pExpr);
      Exit;
    end;
    if ExprHasProperty(p, EP_Skip or EP_IfNullRow) then
    begin
      p  := p^.pLeft;
      op := p^.op;
      Continue;
    end;
    if op <> TK_REGISTER then Break;
    op := p^.op2;
    if op = TK_REGISTER then Break;
  end;
  Result := p^.affExpr;
end;

function sqlite3ExprDataType(const pExpr: PExpr): i32;
var
  p:   PExpr;
  aff: AnsiChar;
begin
  p := pExpr;
  while p <> nil do
  begin
    case p^.op of
      TK_COLLATE, TK_IF_NULL_ROW, TK_UPLUS: p := p^.pLeft;
      TK_NULL: begin Result := 0; Exit; end;
      TK_STRING: begin Result := 2; Exit; end;
      TK_INTEGER, TK_FLOAT: begin Result := 1; Exit; end;
      TK_BLOB: begin Result := 4; Exit; end;
      TK_CAST:
        begin
          if not ExprHasProperty(p, EP_IntValue) then
          begin
            aff := sqlite3AffinityType(p^.u.zToken, nil);
            if Byte(aff) >= SQLITE_AFF_NUMERIC then Result := 1
            else if Byte(aff) = SQLITE_AFF_TEXT then Result := 2
            else Result := 4;
          end else Result := 0;
          Exit;
        end;
    else
      Result := 7;  { may be any type }
      Exit;
    end;
  end;
  Result := 0;
end;

function sqlite3ExprSkipCollate(pExpr: PExpr): PExpr;
begin
  Result := pExpr;
  while (Result <> nil) and ExprHasProperty(Result, EP_Skip or EP_IfNullRow) do
    Result := Result^.pLeft;
end;

function sqlite3ExprSkipCollateAndLikely(pExpr: PExpr): PExpr;
begin
  Result := pExpr;
  while Result <> nil do
  begin
    if ExprHasProperty(Result, EP_Skip or EP_IfNullRow) then
      Result := Result^.pLeft
    else if (Result^.op = TK_FUNCTION) and (Result^.u.zToken <> nil) and
            (sqlite3_strnicmp(Result^.u.zToken, 'likely', 6) = 0) and
            not ExprUseXList(Result) and (Result^.x.pList <> nil) and
            (Result^.x.pList^.nExpr > 0) then
      Result := ExprListItems(Result^.x.pList)^.pExpr
    else
      Break;
  end;
end;

function sqlite3ExprAddCollateToken(pParse: PParse; p: PExpr;
  const pToken: PToken; dequote: i32): PExpr;
var pNew: PExpr;
begin
  if pToken^.n = 0 then begin Result := p; Exit; end;
  pNew := sqlite3ExprAlloc(pParse^.db, TK_COLLATE, pToken, dequote);
  if pNew <> nil then
  begin
    pNew^.pLeft  := p;
    pNew^.flags  := pNew^.flags or EP_Collate or EP_Skip;
  end;
  Result := pNew;
end;

function sqlite3ExprAddCollateString(pParse: PParse; p: PExpr;
  zC: PAnsiChar): PExpr;
var tok: TToken;
begin
  tok.z := zC;
  tok.n := u32(sqlite3Strlen30(zC));
  Result := sqlite3ExprAddCollateToken(pParse, p, @tok, 0);
end;

function sqlite3ExprIsVector(const pExpr: PExpr): i32;
begin
  if ExprUseXList(pExpr) and (pExpr^.op = TK_VECTOR) then Result := 1
  else if ExprUseXSelect(pExpr) and (pExpr^.x.pSelect <> nil)
          and (pExpr^.x.pSelect^.pEList^.nExpr > 1) then Result := 1
  else Result := 0;
end;

function sqlite3ExprVectorSize(const pExpr: PExpr): i32;
begin
  if (pExpr^.op = TK_VECTOR) and ExprUseXList(pExpr) then
    Result := pExpr^.x.pList^.nExpr
  else if ExprUseXSelect(pExpr) and (pExpr^.x.pSelect <> nil) then
    Result := pExpr^.x.pSelect^.pEList^.nExpr
  else
    Result := 1;
end;

function sqlite3IsTrueOrFalse(zIn: PAnsiChar): u32;
begin
  if sqlite3StrICmp(zIn, 'true')  = 0 then Exit(EP_IsTrue);
  if sqlite3StrICmp(zIn, 'false') = 0 then Exit(EP_IsFalse);
  Result := 0;
end;

function sqlite3ExprIdToTrueFalse(pExpr: PExpr): i32;
var v: u32;
begin
  if pExpr^.op <> TK_ID then begin Result := 0; Exit; end;
  if ExprHasProperty(pExpr, EP_IntValue) then begin Result := 0; Exit; end;
  v := sqlite3IsTrueOrFalse(pExpr^.u.zToken);
  if v <> 0 then
  begin
    pExpr^.op     := TK_TRUEFALSE;
    pExpr^.flags  := pExpr^.flags or v;
    Result := 1;
  end else
    Result := 0;
end;

function sqlite3ExprTruthValue(const pExpr: PExpr): i32;
begin
  if ExprHasProperty(pExpr, EP_IsTrue) then Result := 1
  else Result := 0;
end;

function sqlite3IsRowid(z: PAnsiChar): i32;
begin
  if sqlite3StrICmp(z, '_ROWID_') = 0 then Exit(1);
  if sqlite3StrICmp(z, 'ROWID')   = 0 then Exit(1);
  if sqlite3StrICmp(z, 'OID')     = 0 then Exit(1);
  Result := 0;
end;

function sqlite3ExprIsInteger(const p: PExpr; pValue: Pi32;
  pParse: PParse): i32;
var
  rc:   i32;
  v:    i64;
  iVal: i32;
begin
  rc := 0;
  v := 0;
  if ExprHasProperty(p, EP_IntValue) then
  begin
    if pValue <> nil then pValue^ := p^.u.iValue;
    rc := 1;
  end else if p^.op = TK_INTEGER then
  begin
    if (pValue <> nil) and (p^.u.zToken <> nil) then
    begin
      if sqlite3GetInt32(p^.u.zToken, pValue) <> 0 then
        rc := 1;
    end else
      rc := 1;
  end else if p^.op = TK_UPLUS then
    rc := sqlite3ExprIsInteger(p^.pLeft, pValue, pParse)
  else if p^.op = TK_UMINUS then
  begin
    iVal := 0;
    if sqlite3ExprIsInteger(p^.pLeft, @iVal, pParse) <> 0 then
    begin
      if iVal <> Low(i32) then
      begin
        if pValue <> nil then pValue^ := -iVal;
        rc := 1;
      end;
    end;
  end;
  Result := rc;
end;

function sqlite3ExprIsConstant(pParse: PParse; p: PExpr): i32;
begin
  { Minimal implementation — full version uses walker }
  if p = nil then begin Result := 1; Exit; end;
  case p^.op of
    TK_INTEGER, TK_FLOAT, TK_STRING, TK_BLOB, TK_NULL: Result := 1;
  else Result := 0;
  end;
end;

