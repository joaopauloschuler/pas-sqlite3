{$I passqlite3.inc}
unit passqlite3parser;
{
  Phase 7.1 + 7.2 — SQL tokenizer + Lemon LALR(1) parser engine.

  Sources ported:
    sqlite3/src/tokenize.c  (899 lines)  — sqlite3GetToken, sqlite3RunParser
    sqlite3/src/complete.c  (290 lines)  — sqlite3_complete
    sqlite3/src/parse.c     (auto-generated by Lemon, SQLite 3.53.0)
  Generated data inlined:
    sqlite3/parse.h          (TK_* token constants, SQLite 3.53.0)
    sqlite3/keywordhash.h    (keyword perfect-hash tables)

  Phase 7.2f wires sqlite3RunParser to drive the lexer through the engine;
  the previous stub returning SQLITE_ERROR is gone.  See the comment on
  sqlite3RunParser below for the omissions vs. C (sqlite3_log, ParserTrace,
  apVtabLock cleanup, printf-style error formatting).
}

interface

uses
  passqlite3types,
  passqlite3util,
  passqlite3codegen;

