  { --- TKeyInfo (sizeof=32; aColl[FLEXARRAY] follows) --- }
  TKeyInfo = record
    nRef:       u32;                    { 4 bytes @ 0 }
    enc:        u8;                     { 1 byte  @ 4 }
    _pad5:      u8;                     { 1 byte  @ 5 }
    nKeyField:  u16;                    { 2 bytes @ 6 }
    nAllField:  u16;                    { 2 bytes @ 8 }
    _pad10:     array[0..5] of u8;      { 6 bytes @ 10 }
    db:         PTsqlite3;              { 8 bytes @ 16 }
