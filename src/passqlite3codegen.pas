  { --- TInLoop (sizeof=20) --- }
  TInLoop = record
    iCur:       i32;              { 4 bytes @ 0 }
    addrInTop:  i32;              { 4 bytes @ 4 }
    iBase:      i32;              { 4 bytes @ 8 }
    nPrefix:    i32;              { 4 bytes @ 12 }
    eEndLoopOp: u8;               { 1 byte  @ 16 }
