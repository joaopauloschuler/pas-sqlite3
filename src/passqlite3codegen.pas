// ---------------------------------------------------------------------------
// Expression size constants (from sqliteInt.h, verified vs GCC x86-64)
// EXPR_FULLSIZE=72, EXPR_REDUCEDSIZE=44, EXPR_TOKENONLYSIZE=16
// ---------------------------------------------------------------------------

const
  EXPR_FULLSIZE       = 72;  { sizeof(TExpr) }
  EXPR_REDUCEDSIZE    = 44;  { offsetof(TExpr, iTable) }
  EXPR_TOKENONLYSIZE  = 16;  { offsetof(TExpr, pLeft) }
  EXPRDUP_REDUCE      = 1;   { flag: use reduced-size Expr nodes }

  { SZ_EXPRLIST(N) = 8 + N*24  (sizeof(TExprList)=8, sizeof(TExprListItem)=24) }
  SZ_EXPRLIST_HEADER  = 8;   { SizeOf(TExprList) }
  SZ_EXPRLIST_ITEM    = 24;  { SizeOf(TExprListItem) }
  { SZ_SRCLIST(N) = 8 + N*72 }
  SZ_SRCLIST_HEADER   = 8;   { SizeOf(TSrcList) }
  SZ_SRCLIST_ITEM     = 72;  { SizeOf(TSrcItem) }
  { SZ_IDLIST(N) = 8 + N*8 }
  SZ_IDLIST_HEADER    = 8;   { SizeOf(TIdList) }
  SZ_IDLIST_ITEM      = 8;   { SizeOf(TIdListItem) }
  { SZ_WITH(N): sizeof(TWith_header)=16, sizeof(TCte)=48 }
  SZ_WITH_HEADER      = 16;
  SZ_CTE              = 48;
  { Sort order constants }
  SQLITE_SO_UNDEFINED = -1;
  SQLITE_SO_ASC       = 0;
  SQLITE_SO_DESC      = 1;

  { SQLITE_LIMIT_* indices (sqliteInt.h) }
